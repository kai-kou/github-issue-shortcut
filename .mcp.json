{
  "mcpServers": {
    "context7": {
      "type": "http",
      "url": "${CONTEXT7_URL:-https://mcp.context7.com/mcp}",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY:-}"
      }
    },
    "github": {
      "type": "http",
      "url": "${GITHUB_MCP_URL:-https://api.githubcopilot.com/mcp/}",
      "headers": {
        "Authorization": "Bearer ${GH_TOKEN:-}"
      }
    }
  }
}
