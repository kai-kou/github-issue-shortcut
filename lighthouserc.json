{
  "ci": {
    "collect": {
      "url": ["http://localhost:8789/"],
      "startServerCommand": "npx wrangler dev --port 8789 --var GITHUB_CLIENT_ID:lhci-client-id --var GITHUB_CLIENT_SECRET:lhci-client-secret --var TOKEN_ENCRYPTION_KEY:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA= --var GITHUB_OAUTH_BASE:http://localhost:8788 --var GITHUB_API_BASE:http://localhost:8788",
      "startServerReadyPattern": "Ready on",
      "startServerReadyTimeout": 60000,
      "numberOfRuns": 3,
      "settings": {
        "formFactor": "mobile",
        "screenEmulation": { "mobile": true, "width": 412, "height": 823, "deviceScaleFactor": 2.625, "disabled": false },
        "onlyCategories": ["performance", "accessibility"],
        "chromeFlags": "--no-sandbox --headless=new"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.8 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.1 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 200 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
