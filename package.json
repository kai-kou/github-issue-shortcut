{
  "name": "github-issue-shortcut",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "npm run build && playwright test",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "size": "size-limit"
  },
  "size-limit": [
    {
      "name": "クライアントバンドル（brotli）",
      "path": "dist/client/assets/*.js",
      "limit": "80 KB"
    },
    {
      "name": "Worker バンドル（brotli）",
      "path": "dist/github_issue_shortcut/index.js",
      "limit": "35 KB"
    }
  ],
  "dependencies": {
    "hono": "^4.12.28",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260710.1",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "size-limit": "^12.1.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
