{
  "model": "claude-sonnet-5",
  "outputStyle": "concise-neko",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "permissions": {
    "allow": [
      "Skill",
      "Bash(sleep:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(bash -n:*)",
      "Bash(gh:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(python3:*)",
      "Bash(pip3:*)",
      "Read(.claude)",
      "Read(.github)",
      "Read(docs)",
      "Read(CLAUDE.md)",
      "Read(tools)",
      "Edit(.claude)",
      "Edit(.github)",
      "Edit(docs)",
      "Edit(CLAUDE.md)",
      "Edit(tools)",
      "Write(.claude)",
      "Write(.github)",
      "Write(docs)",
      "Write(tools)",
      "WebSearch",
      "WebFetch",
      "mcp__context7__resolve-library-id",
      "mcp__context7__get-library-docs",
      "mcp__github__add_issue_comment",
      "mcp__github__create_branch",
      "mcp__github__create_or_update_file",
      "mcp__github__create_pull_request",
      "mcp__github__get_file_contents",
      "mcp__github__issue_read",
      "mcp__github__issue_write",
      "mcp__github__list_branches",
      "mcp__github__list_commits",
      "mcp__github__list_issues",
      "mcp__github__list_pull_requests",
      "mcp__github__merge_pull_request",
      "mcp__github__pull_request_read",
      "mcp__github__pull_request_review_write",
      "mcp__github__push_files",
      "mcp__github__resolve_review_thread",
      "mcp__github__search_code",
      "mcp__github__search_issues",
      "mcp__github__subscribe_pr_activity",
      "mcp__github__unsubscribe_pr_activity",
      "mcp__github__update_pull_request",
      "mcp__Cloudflare_API__execute",
      "mcp__Cloudflare_API__search",
      "mcp__Cloudflare_Developer_Platform__d1_database_query",
      "mcp__Cloudflare_Developer_Platform__d1_databases_list"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/credentials*)",
      "Read(**/id_rsa)",
      "Read(**/id_ed25519)",
      "Read(**/.aws/**)",
      "Read(**/*service-account*.json)",
      "Write(.claude/settings.local.json)",
      "Edit(.claude/settings.local.json)"
    ]
  },
  "autoMode": {
    "allow": [
      "$defaults",
      "`git push --force-with-lease` targeting a working branch (claude/*, feat/*, fix/*, docs/*): this project restarts already-merged working branches each sprint, which requires a force-with-lease push over the merged history. Direct pushes to main remain blocked by the pre-push hook (A-1), so this is safe.",
      "`mcp__Cloudflare_API__execute` / `mcp__Cloudflare_API__search` and `mcp__Cloudflare_Developer_Platform__d1_database_query` / `d1_databases_list`: Claude autonomously manages this project's own Cloudflare Worker and D1 (Secrets, vars, D1 schema/migrations/queries, deploy verification). Approved by the project owner for hands-off operation.",
      "`mcp__Cloudflare_API__execute` calling `PATCH /accounts/{account_id}/builds/workers/{script_tag}` to change this project's Workers Builds `production_settings` (e.g. `deploy_command`, `build_command`): explicitly approved by the project owner (2026-07-17, Issue #55 — adding `wrangler d1 migrations apply DB --remote` to the deploy command) for hands-off operation on this repo's own Worker build config. Does not extend to other accounts/projects."
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "github.com",
        "api.github.com",
        "slack.com",
        "api.slack.com",
        "api.anthropic.com",
        "mcp.context7.com",
        "context7.com"
      ]
    },
    "excludedCommands": [
      "python3 *tools/*.py",
      "python *tools/*.py",
      "timeout * python3 *tools/*.py",
      "timeout * python *tools/*.py"
    ]
  },
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [
        { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/user-prompt-submit-guard.sh" },
        { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/prompt-structuring.sh" },
        { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/orchestrator-directive.sh" }
      ] }
    ],
    "PermissionRequest": [
      { "matcher": "Read|Write|Edit|NotebookEdit", "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/permission-request-auto-allow.sh" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Bash|mcp__github__create_pull_request", "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-tool-use-router.sh" } ] }
    ],
    "PostToolUse": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use-validate.sh" } ] }
    ],
    "PostToolUseFailure": [
      { "matcher": "Bash", "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-tool-use-failure.sh" } ] }
    ],
    "PreCompact": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact.sh" } ] }
    ],
    "PostCompact": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-compact.sh" } ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-router.sh" } ] }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/subagent-stop.sh" } ] }
    ]
  }
}
